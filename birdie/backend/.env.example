# Database — get this from Railway after adding a Postgres plugin
DATABASE_URL="postgresql://user:password@host:port/dbname"

# JWT — make this a long random string, keep it secret
JWT_SECRET="replace-this-with-a-long-random-secret-string"

# Google OAuth — get from Google Cloud Console
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Frontend URL — for CORS (change to your Vercel URL in production)
FRONTEND_URL="http://localhost:3000"

# Port
PORT=4000
